    "patients = [\"P1\", \"P2\", \"P3\"]\n",
    "sessions = [\"pre\", \"post\"]\n",
    "\n",
    "all_results = {}\n",
    "\n",
    "for patient in patients:\n",
    "    all_results[patient] = {}\n",
    "\n",
    "    for session in sessions:\n",
    "        train_file = os.path.join(DATA_DIR, f\"{patient}_{session}_training.mat\")\n",
    "        test_file  = os.path.join(DATA_DIR, f\"{patient}_{session}_test.mat\")\n",
    "\n",
    "        # Skip running if files aren't in your directory yet\n",
    "        if not os.path.exists(train_file) or not os.path.exists(test_file):\n",
    "            print(f\"Skipping {patient} {session}: files not found.\")\n",
    "            continue\n",
    "\n",
    "        result = run_riemann_mdm_with_all_accuracies(\n",
    "            train_file=train_file,\n",
    "            test_file=test_file,\n",
    "            tmin=2.0,\n",
    "            tmax=7.0,\n",
    "            cv_folds=5,\n",
    "            plot_confusion=True # Turn to True if you want a chart for every session\n",
    "        )\n",
    "\n",
    "        all_results[patient][session] = result\n"
   ]
